{
  "name": "ott-backend",
  "version": "1.0.0",
  "description": "OTT Platform Backend - Express.js + Prisma",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/workers/transcode.worker.js",

    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "studio": "prisma studio",

    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "node src/prisma/seed.js",

    "seed-admin": "node scripts/seed-admin.js",
    "minio:setup": "node src/config/minio-setup.js",

    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "firebase-admin": "^12.6.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}