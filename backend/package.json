{
  "name": "ott-backend",
  "version": "1.0.0",
  "description": "OTT Platform Backend - Express.js + Prisma",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/transcode.worker.js",
    "start": "node src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:seed": "node src/prisma/seed.js",
    "minio:setup": "node src/config/minio-setup.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.13.3",
    "@prisma/client": "^5.20.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.12.0",
    "minio": "^8.0.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "firebase-admin": "^12.6.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "prisma": {
  "schema": "src/prisma/schema.prisma"
}

}



