# Copy this file to .env and fill in your values

# App Info (from main)
APP_NAME="OTT Backend"

# Application Environment (main priority)
NODE_ENV="development"
PORT=3000

# Debug Options (from main)
DEBUG_QUERIES=false
LOG_LEVEL="info"

# Database Configuration (main kept)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Redis (from admin_ui)
REDIS_URL=redis://localhost:6379

# JWT (from admin_ui)
JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# MinIO (from admin_ui)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ott-media
MINIO_USE_SSL=false

# Meilisearch (from admin_ui)
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=devmasterkey123

# Security (from admin_ui)
BCRYPT_SALT_ROUNDS=10